# Required: PostgreSQL connection string
# Use your actual credentials and host values.
# Example local format:
# DATABASE_URL=postgresql://postgres:password@localhost:5432/living_library
DATABASE_URL=

# Optional: Supabase storage integration
SUPABASE_URL=
SUPABASE_KEY=

# Optional: local PDF storage root (default is ./pdfs)
PDF_BASE_DIR=./pdfs

# Optional: backend log level
LOG_LEVEL=INFO
